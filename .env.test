# iFirma API integration test credentials.
# Copy this file to .env.test.local and fill in real values to run integration tests.
# .env.test.local is gitignored and never committed.

IFIRMA_USERNAME=
IFIRMA_INVOICE_KEY=
IFIRMA_SUBSCRIBER_KEY=
# Optional — required only for expense tests
IFIRMA_EXPENSE_KEY=
